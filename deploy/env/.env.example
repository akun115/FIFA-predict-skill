# World Cup Oracle — Environment Variables (Placeholder Template)
#
# TEMPLATE ONLY.  All values are PLACEHOLDERS.
# Copy to .env and provide real credentials for live mode.
# NEVER commit .env with real credentials to version control.
#
# Default mode: OFFLINE.  No network, no env reads.

# ── Runtime mode ──
# offline: no network, no env reads (default, fail-closed)
# synthetic: FIC-* fictional data only
# live_opt_in: requires explicit opt-in + valid credentials
WORLD_CUP_ORACLE_RUNTIME_MODE=offline

# ── Network / env access ──
WORLD_CUP_ORACLE_NETWORK_ALLOWED=false
WORLD_CUP_ORACLE_ENV_ACCESS_ALLOWED=false

# ── Deployment ──
WORLD_CUP_ORACLE_DEPLOYMENT_ENVIRONMENT=local-dev

# ── Output paths ──
WORLD_CUP_ORACLE_OUTPUT_PATH=./output
WORLD_CUP_ORACLE_LOG_PATH=./output/logs
WORLD_CUP_ORACLE_SNAPSHOT_STORE_PATH=./output/snapshots

# ── Monitoring ──
WORLD_CUP_ORACLE_MONITORING_ENABLED=false

# ── Providers (all disabled by default) ──

# TheSportsDB public test key (free, no account required)
# TheSportsDB remains needs_more_info — NOT approved_for_live_adapter
# WORLD_CUP_ORACLE_THESPORTSDB_API_KEY=<your_key_here>
# WORLD_CUP_ORACLE_THESPORTSDB_BASE_URL=https://www.thesportsdb.com

# API-Football (free tier requires account — NOT configured)
# WORLD_CUP_ORACLE_API_FOOTBALL_KEY=<your_key_here>

# football-data.org (free tier requires account — NOT configured)
# WORLD_CUP_ORACLE_FOOTBALL_DATA_ORG_API_KEY=<your_key_here>

# Odds provider (NOT configured)
# WORLD_CUP_ORACLE_ODDS_PROVIDER=
# WORLD_CUP_ORACLE_ODDS_API_KEY=<your_key_here>

# Web Scout / Search provider (NOT configured)
# WORLD_CUP_ORACLE_WEB_SCOUT_PROVIDER=
# WORLD_CUP_ORACLE_WEB_SCOUT_API_KEY=<your_key_here>

# ── Live test opt-in ──
# Requires explicit activation + valid credentials
# WORLD_CUP_ORACLE_LIVE_PROVIDER_TESTS=0
